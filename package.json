{
  "name": "toon_castle",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "rimraf dist && tsc && vite build",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:cov": "vitest run --coverage",
    "clean": "rimraf dist",
    "preview": "vite preview",
    "type-check": "tsc --noEmit"
  },
  "overrides": {
    "ajv": "^8.18.0",
    "minimatch": "^10.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "jiti": "^2.6.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite": "^7.2.4",
    "vite-plugin-phaser": "^0.0.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  }
}
